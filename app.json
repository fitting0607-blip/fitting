{
  "expo": {
    "name": "핏팅",
    "slug": "fitting",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fitting",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hywoo.fitting",
      "buildNumber": "2",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "프로필 사진 등록 및 게시물 업로드를 위해 사진 라이브러리에 접근합니다. 선택한 사진은 핏팅 앱 내에서만 사용됩니다."
      }
    },
    "android": {
      "package": "com.hywoo.fitting",
      "icon": "./assets/images/android-icon.png",
      "adaptiveIcon": {
        "backgroundColor": "#3B3BF9",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-build-properties",
        {
          "ios": {
            "googleMobileAdsAppId": "ca-app-pub-7157702052156983~4127678119"
          },
          "android": {
            "googleMobileAdsAppId": "ca-app-pub-7157702052156983~2749009654",
            "kotlinVersion": "2.2.0"
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-7157702052156983~2749009654",
          "iosAppId": "ca-app-pub-7157702052156983~4127678119"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "지도에서 내 위치와 주변 트레이너를 보기 위해 위치 접근이 필요해요."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
